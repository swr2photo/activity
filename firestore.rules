rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getAdminData() {
      return get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid)) &&
        getAdminData().isActive == true;
    }

    function getStudentData() {
      return get(/databases/$(database)/documents/universityUsers/$(request.auth.uid)).data;
    }

    function isActivityOpen(activityDocId) {
      let activity = get(/databases/$(database)/documents/activityQRCodes/$(activityDocId)).data;
      let active = activity.get('isActive', true) != false &&
        (activity.get('maxParticipants', 0) == 0 || activity.get('currentParticipants', 0) < activity.get('maxParticipants', 0));
      let sessions = activity.get('sessions', []);
      // หลายรอบ: ไม่บังคับหน้าต่างเวลาที่ระดับ activity (ตรวจรอบที่เปิดอยู่ฝั่ง client แล้ว)
      let inSessionMode = sessions is list && sessions.size() > 0;
      let inWindow = (!('startDateTime' in activity) || request.time >= activity.startDateTime) &&
        (!('endDateTime' in activity) || request.time <= activity.endDateTime);
      return active && (inSessionMode || inWindow);
    }

    // 1. adminUsers
    match /adminUsers/{uid} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == uid);
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    // 2. adminInvites
    match /adminInvites/{inviteId} {
      allow read: if isAuthenticated(); // Anyone logged in can check if they are invited
      allow write: if isAdmin();
    }

    // 3. activities & activityQRCodes (PRIMARY_ACTIVITY_COLLECTION)
    match /activities/{activityId} {
      allow read: if true; // Publicly readable for registration page
      allow write: if isAdmin();
    }
    match /activityQRCodes/{qrId} {
      allow read: if true; // Publicly readable for registration page
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentParticipants']) &&
        request.resource.data.currentParticipants == (resource.data.currentParticipants == null ? 0 : resource.data.currentParticipants) + 1
      );
    }

    // 4. activityRecords (Registration records)
    match /activityRecords/{recordId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        (exists(/databases/$(database)/documents/universityUsers/$(request.auth.uid)) &&
         resource.data.studentId == getStudentData().studentId)
      );
      allow create: if isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/universityUsers/$(request.auth.uid)) &&
         getStudentData().get('isActive', true) != false &&
         request.resource.data.userId == request.auth.uid &&
         request.resource.data.studentId == getStudentData().studentId &&
         isActivityOpen(request.resource.data.activityDocId))
      );
      // เจ้าของอัปเดตได้เฉพาะเช็กอินรอบถัดไป (คง userId/studentId/activityCode)
      allow update: if isAdmin() || (
        isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.studentId == resource.data.studentId &&
        request.resource.data.activityCode == resource.data.activityCode &&
        request.resource.data.activityDocId == resource.data.activityDocId
      );
      allow delete: if isAdmin();
    }

    // 5. universityUsers (Student profiles)
    // เจ้าของแก้โปรไฟล์ตัวเองได้ แต่ห้ามแก้สถานะบัญชี (isActive / isVerified)
    match /universityUsers/{uid} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == uid);
      allow create: if isAuthenticated() && (
        isAdmin() || (
          request.auth.uid == uid &&
          request.resource.data.get('isActive', true) == true
        )
      );
      allow update: if isAdmin() || (
        isAuthenticated() && request.auth.uid == uid &&
        request.resource.data.get('isActive', true) == resource.data.get('isActive', true) &&
        request.resource.data.get('isVerified', true) == resource.data.get('isVerified', true)
      );
      allow delete: if isAdmin();
    }

    // 6. logs (System logs)
    match /logs/{logId} {
      allow read, write: if isAdmin();
    }

    // 7. ipLoginRecords (IP limits for verification)
    match /ipLoginRecords/{recordId} {
      allow read: if true;
      allow create, update: if true 
        && request.resource.data.keys().hasAll(['ipAddress', 'userEmail', 'loginTime', 'expiresAt'])
        && request.resource.data.ipAddress is string
        && request.resource.data.userEmail is string
        && request.resource.data.ipAddress.size() < 50
        && request.resource.data.userEmail.size() < 150;
      allow delete: if isAdmin();
    }

    // 8. errorReports (Frontend errors)
    match /errorReports/{reportId} {
      allow create: if true 
        && request.resource.data.keys().hasAll(['message', 'createdAt'])
        && request.resource.data.message is string
        && request.resource.data.message.size() < 10000;
      allow read, update, delete: if isAdmin();
    }

    // 9. departments (Faculty / department list)
    match /departments/{deptId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    // 10. systemSettings (Global settings)
    match /systemSettings/{settingId} {
      allow read: if true; // Publicly readable (e.g. check maintenance mode)
      allow write: if isAdmin();
    }

    // 11. customShortLinks
    match /customShortLinks/{linkId} {
      allow read, write: if isAdmin();
    }

    // 12. shortLinkVisits
    match /shortLinkVisits/{visitId} {
      allow read: if isAdmin();
      allow write: if false; // Only written via Admin SDK on the server
    }

    // 13. surveyResponses (คำตอบแบบประเมินกิจกรรม)
    match /surveyResponses/{responseId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 14. users (โปรไฟล์ compat เดิม — mirror ของ universityUsers)
    // กฎเดียวกับ universityUsers: ห้ามเจ้าของแก้สถานะบัญชีเอง
    match /users/{uid} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == uid);
      allow create: if isAuthenticated() && (
        isAdmin() || (
          request.auth.uid == uid &&
          request.resource.data.get('isActive', true) == true
        )
      );
      allow update: if isAdmin() || (
        isAuthenticated() && request.auth.uid == uid &&
        request.resource.data.get('isActive', true) == resource.data.get('isActive', true) &&
        request.resource.data.get('isVerified', true) == resource.data.get('isVerified', true)
      );
      allow delete: if isAdmin();
    }

    // 15. adminSettings (การตั้งค่าแบรนด์/ฟอร์มลงทะเบียน — หน้า register ต้องอ่านได้)
    match /adminSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 16. loginSessions (เซสชันจำกัดการล็อกอินของนักศึกษา)
    match /loginSessions/{uid} {
      allow read, write: if isAuthenticated() && (isAdmin() || request.auth.uid == uid);
    }

    // 17. activityClaims (โหมดผู้ใช้เดียว — จองสิทธิ์ระหว่างทำ transaction ลงทะเบียน)
    match /activityClaims/{claimId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // 18. adminNotifications (กระดิ่งแจ้งเตือนในหน้าแอดมิน)
    match /adminNotifications/{notifId} {
      allow read, write: if isAdmin();
    }
  }
}
