rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: checks if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: checks if user is an active admin in Firestore
    function isAdmin() {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/adminUsers/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/adminUsers/$(request.auth.uid)).data.isActive == true;
    }

    // 1. Activity banners
    match /banners/{department}/{filename} {
      allow read: if true; // Public read
      allow write: if isAdmin(); // Active admin write
    }

    // 2. Admin profile pictures
    match /admin-profiles/{uid}/{filename} {
      allow read: if true; // Public read
      allow write: if isAuthenticated() && request.auth.uid == uid && isAdmin(); // Owner write, and must be admin
    }
  }
}
